{
    "require-for-phase-6": {
        "barryvdh/laravel-dompdf": "^2.1",
        "maatwebsite/laravel-excel": "^3.1",
        "dompdf/dompdf": "^2.0"
    },
    "installation-commands": [
        "composer require barryvdh/laravel-dompdf:^2.1",
